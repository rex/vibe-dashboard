# --- Xcode ---
# .xcodeproj is regenerated by xcodegen — project.yml is the source of truth.
*.xcodeproj
*.xcodeproj/
xcuserdata/
DerivedData/
build/
*.xcarchive
*.dSYM
*.dSYM.zip
*.app
*.hmap

# Generated by Scripts/generate-build-info.sh.
**/Generated/BuildInfo.swift

# Swift Package Manager build / cache.
.build/
.swiftpm/
Package.resolved

# --- Signing — NEVER commit these ---
*.p12
*.mobileprovision
*.cer
*.p8
AuthKey_*.p8

# --- Per-developer / runtime config ---
.env
.env.*
Environment.plist
*.local.swift

# --- CocoaPods / Carthage — FORBIDDEN; belt-and-suspenders. ---
Podfile
Podfile.lock
Pods/
Cartfile
Cartfile.resolved
Carthage/

# --- Test results / coverage ---
*.xcresult
*.profraw
*.profdata

# --- OS / editor noise ---
.DS_Store
.AppleDouble
*.swp
*~
.idea/
.vscode/

# --- Serena / agent scaffolding ---
.serena/cache/
.claude/serena-initialized
